# ─── Horizon AI — environment configuration ──────────────────────────────
# Copy to .env and fill in. NEVER commit .env to version control.
# All keys previously pasted into AI chats must be rotated before use.

# OpenAI (script generation, trim analysis, aesthetic routing)
OPENAI_API_KEY=

# ElevenLabs (voiceover synthesis)
ELEVENLABS_API_KEY=

# Shotstack (video rendering) — set SHOTSTACK_ENV to "stage" or "v1" (production)
SHOTSTACK_API_KEY=
SHOTSTACK_ENV=stage

# Supabase (system database + music/asset storage)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stock footage sources (both have free tiers)
PEXELS_API_KEY=
PIXABAY_API_KEY=
# Keep true in production: reject stock clips that fail visual relevance QA.
VISUAL_QUALITY_GATE=true

# ─── Apify / VideoIntel API (Universal video metadata & download) ─────────
# Get from: https://apify.com/upworkprashantp/videointel-video-metadata-extractor
APIFY_API_KEY=
APIFY_ACTOR_ID=upworkprashantp/videointel-video-metadata-extractor

# ─── AI Quality Gate ──────────────────────────────────────────────────────
# Set to "strict" to reject scripts scoring below threshold
QUALITY_GATE_STRICTNESS=normal  # normal | strict | permissive
QUALITY_SCORE_THRESHOLD=7.0     # Minimum virality score to proceed (1-10)

# ─── Content Generation ──────────────────────────────────────────────────
# Enable AI-generated B-roll (uses a compatible image-to-video API)
ENABLE_AI_BROLL=false
AI_BROLL_API_KEY=  # For services like Runway, Pika, or Stable Video Diffusion

# ─── Cost Management ──────────────────────────────────────────────────────
# Maximum cost per video run in USD (prevents runaway spending)
MAX_COST_PER_VIDEO=5.00
DAILY_COST_CAP=50.00

# Optional: JSON map of headers for RSS feeds you are authorised to access.
# Reference a map key through social_rss_feeds[].auth_key in Supabase.
SOCIAL_RSS_HEADERS={"creator_feed":{"Authorization":"Bearer replace-me"}}

# Optional — Long-form clipper (Agent 6): a Vimeo personal access token
# (developer.vimeo.com/apps → your app → Generate an access token, scope
# "private") lets you feed in YOUR OWN Vimeo videos. Vimeo's API only
# returns a "download" link for videos that token's account owns/has
# download rights to, so this can't be used against third-party videos.
VIMEO_ACCESS_TOKEN=

# Google / YouTube Data API v3 (OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth2callback
# Generated by `npm run auth:youtube` after first consent:
GOOGLE_REFRESH_TOKEN=

# Server
PORT=8080
DASHBOARD_PASSWORD=change-me

# Pipeline
PIPELINE_CRON=0 3 * * *        # 03:00 UTC daily
VIDEOS_PER_RUN=6               # one per active niche (Gaming/Lore, Aesthetic, Psychology, Travel, News, Food)
AUTOPILOT=true                 # false = render but hold uploads for manual approval