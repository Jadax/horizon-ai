# ─── Horizon AI — Full Setup ──────────────────────────────────────────

# ─── OpenAI (keep – small usage) ────────────────────────────────────
OPENAI_API_KEY=your_openai_key

# ─── TTS Configuration ──────────────────────────────────────────────
# "chatterbox" requires you to deploy your own HTTP wrapper around the
# resemble-ai/chatterbox Python library first — it ships as a library, not a
# server, so this does nothing out of the box. Use "gtts" to actually work
# without extra services (shells out to python3 -m gtts, needs python3 + the
# gtts pip package installed wherever horizon-ai itself runs).
TTS_ENGINE=gtts
# Internal URL when all services are in same Railway project (only used if TTS_ENGINE=chatterbox/fish-speech/coqui)
TTS_API_URL=http://tts-server:5000/tts
# Fallback if the primary engine fails
TTS_FALLBACK=gtts

# ─── Render API Configuration ──────────────────────────────────────
# "render-api" points at a self-hosted juppfy/render-video-api deployment,
# which needs its own DATABASE_URL, JWT_SECRET, and S3-compatible bucket
# configured (see render-api/README.md) before it will even start, plus a
# RENDER_API_KEY generated through its dashboard (below) — set RENDER_ENGINE
# to anything else to just use the FFmpeg fallback (works without extra services).
RENDER_ENGINE=render-api
RENDER_API_URL=http://render-api:3000
RENDER_API_KEY=
# Fallback to FFmpeg if render-api fails or isn't configured

# ─── Stock Footage (Free) ──────────────────────────────────────────
PEXELS_API_KEY=your_pexels_key
PIXABAY_API_KEY=your_pixabay_key
VISUAL_QUALITY_GATE=true
BYPASS_QA_FOR_SOURCE=true

# ─── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_key

# ─── YouTube Upload ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth2callback
GOOGLE_REFRESH_TOKEN=your_refresh_token

# ─── Server ────────────────────────────────────────────────────────
PORT=8080
DASHBOARD_PASSWORD=your_password
PIPELINE_CRON=0 3 * * *
VIDEOS_PER_RUN=6
AUTOPILOT=true
QUALITY_GATE_MODE=warn_only
QUALITY_SCORE_THRESHOLD=7.0

# ─── Affiliate (Optional) ─────────────────────────────────────────
AFFILIATE_TRACKING_ID=your-tag-20

# ─── Long-form clipper (Agent 6) — optional ────────────────────────
# Personal access token for YOUR OWN Vimeo account (scope "private") — only
# works against videos that token's account owns/has download rights to.
VIMEO_ACCESS_TOKEN=