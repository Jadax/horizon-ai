# ─── Horizon AI — environment configuration ──────────────────────────────
# Copy to .env and fill in. NEVER commit .env to version control.
# All keys previously pasted into AI chats must be rotated before use.

# OpenAI (script generation, trim analysis, aesthetic routing)
OPENAI_API_KEY=

# ElevenLabs (voiceover synthesis)
ELEVENLABS_API_KEY=

# Shotstack (video rendering) — set SHOTSTACK_ENV to "stage" or "v1" (production)
SHOTSTACK_API_KEY=
SHOTSTACK_ENV=stage

# Supabase (system database + music/asset storage)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stock footage sources (both have free tiers)
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Google / YouTube Data API v3 (OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth2callback
# Generated by `npm run auth:youtube` after first consent:
GOOGLE_REFRESH_TOKEN=

# Server
PORT=8080
DASHBOARD_PASSWORD=change-me

# Pipeline
PIPELINE_CRON=0 3 * * *        # 03:00 UTC daily
VIDEOS_PER_RUN=5               # one per active niche (Gaming/Lore, Aesthetic, Psychology, Travel, News)
AUTOPILOT=true                 # false = render but hold uploads for manual approval
