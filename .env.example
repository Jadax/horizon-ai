# ─── Horizon AI — Full Setup ──────────────────────────────────────────

# ─── OpenAI (keep – small usage) ────────────────────────────────────
OPENAI_API_KEY=your_openai_key

# ─── Gemini (free tier — primary LLM) ───────────────────────────────
# When set, ALL text-only LLM calls (scripts, quality critic, trims,
# format decisions, viral scoring) route through Gemini's free tier first
# (gemini-flash-latest → gemini-flash-lite-latest), with OpenAI as the
# paid fallback. Get a free key at https://aistudio.google.com.
GEMINI_API_KEY=

# ─── Image generation ───────────────────────────────────────────────
# "pollinations" (default): free FLUX-based generation, no key, $0 — used
# for illustrated-mode frames, gpt-image-1 as automatic fallback.
# "openai": force gpt-image-1 for everything (paid).
IMAGE_ENGINE=pollinations

# ─── Music library sync (optional) ──────────────────────────────────
# Free client_id from https://devportal.jamendo.com — then run
# `npm run music:sync` to pull CC-BY tracks into music_library, tagged to
# the pipeline's energy levels. Pixabay/Uppbeat have no APIs; stock those
# manually into music_library if preferred.
JAMENDO_CLIENT_ID=

# ─── TTS Configuration — runs in-process, single Railway service ──────
# "openai" (default): gpt-4o-mini-tts via your existing OPENAI_API_KEY —
# natural human-sounding narration, ~$0.01 per video. Falls back to gtts
# automatically on failure.
# "gtts": free but robotic; shells out to python3 -m gtts in this same
# container (nixpacks.toml installs python3 + gTTS during Railway builds).
# "chatterbox"/"fish-speech"/"coqui" instead call out to TTS_API_URL below,
# which means deploying and maintaining a whole separate TTS server
# yourself first — resemble-ai/chatterbox itself is just a Python library,
# not a server, so that path needs real extra engineering, not just a URL.
TTS_ENGINE=openai
TTS_API_URL=http://localhost:5000/tts
TTS_FALLBACK=gtts

# ─── Render Configuration — runs in-process, single Railway service ───
# "ffmpeg" (the default — any value other than "render-api"/"shottower"
# works) renders locally via the bundled ffmpeg-static npm dependency. No
# separate service, no database, no bucket, no extra config needed.
# "render-api" instead calls out to a self-hosted juppfy/render-video-api
# deployment, which needs its own DATABASE_URL, JWT_SECRET, S3-compatible
# bucket, and a RENDER_API_KEY generated through its dashboard — a second,
# separately-provisioned service, not something this repo can bundle in.
RENDER_ENGINE=ffmpeg
RENDER_API_URL=http://localhost:3000
RENDER_API_KEY=

# ─── Stock Footage (Free) ──────────────────────────────────────────
PEXELS_API_KEY=your_pexels_key
PIXABAY_API_KEY=your_pixabay_key
VISUAL_QUALITY_GATE=true
BYPASS_QA_FOR_SOURCE=true
# Generates an OpenAI image for a script beat with no real stock match,
# instead of forcing a mismatched clip. Real per-image cost, capped at
# 4/video. Set false to just skip beats with no stock match instead.
ENABLE_AI_CUTAWAY=true

# ─── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_key

# ─── YouTube Upload ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth2callback
GOOGLE_REFRESH_TOKEN=your_refresh_token

# ─── Server ────────────────────────────────────────────────────────
PORT=8080
DASHBOARD_PASSWORD=your_password
PIPELINE_CRON=0 3 * * *
VIDEOS_PER_RUN=6
AUTOPILOT=true
CONTENT_QUALITY_THRESHOLD=78
SUBTITLE_SYNC_PRECISION_MS=50
PUBLISH_PLATFORMS=youtube,tiktok,instagram,linkedin
QUALITY_SCORE_THRESHOLD=7.0

# ─── Affiliate (Optional) ─────────────────────────────────────────
AFFILIATE_TRACKING_ID=your-tag-20

# ─── Long-form clipper (Agent 6) — optional ────────────────────────
# Personal access token for YOUR OWN Vimeo account (scope "private") — only
# works against videos that token's account owns/has download rights to.
VIMEO_ACCESS_TOKEN=

# ─── Telegram approval notifications (optional, free) ───────────────
# @BotFather → /newbot → token; message your bot once, then use
# /getUpdates to find your chat id. PUBLIC_URL = your Railway app URL so
# the one-tap Approve button works away from localhost.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PUBLIC_URL=

# ─── Leo (local cat-video niche) ────────────────────────────────────
# Drop videos (optionally with a same-named .txt of what to say) into
# LEO_INBOX_DIR and run `npm run leo:sync` (schedule it with Task
# Scheduler for daily cadence). LEO_VOICE_ID + ELEVENLABS_API_KEY = the
# cloned personal voice (consent + ~$5/mo); unset = OpenAI "coral".
LEO_INBOX_DIR=leo_inbox
LEO_VOICE_ID=
ELEVENLABS_API_KEY=
