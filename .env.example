# ─── Horizon AI — environment configuration ──────────────────────────────
# Copy to .env and fill in. NEVER commit .env to version control.

# OpenAI (script generation, trim analysis, aesthetic routing)
OPENAI_API_KEY=

# ElevenLabs (voiceover synthesis)
ELEVENLABS_API_KEY=

# Shotstack (video rendering) — set SHOTSTACK_ENV to "stage" or "v1" (production)
SHOTSTACK_API_KEY=
SHOTSTACK_ENV=stage

# Supabase (system database + music/asset storage)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stock footage sources (both have free tiers)
PEXELS_API_KEY=
PIXABAY_API_KEY=
VISUAL_QUALITY_GATE=true

# ─── Apify / VideoIntel API (Universal video metadata & download) ─────────
APIFY_API_KEY=
APIFY_ACTOR_ID=upworkprashantp/videointel-video-metadata-extractor

# ─── AI Quality Gate ──────────────────────────────────────────────────────
QUALITY_SCORE_THRESHOLD=7.0     # Minimum virality score to proceed (1-10)
# Set to "warn_only" to log issues but not fail the run
QUALITY_GATE_MODE=warn_only     # fail | warn_only

# ─── Monetization ──────────────────────────────────────────────────────────
# REQUIRED: Your actual Amazon Associate tracking ID - DO NOT use placeholder
AFFILIATE_TRACKING_ID=your-tag-20

# Optional: API key for affiliate product search (if using API-based matching)
AFFILIATE_API_KEY=

# Multi-platform publishing (comma-separated, ONLY platforms with real API keys)
# Currently only "youtube" is fully implemented
PUBLISH_TO=youtube

# ─── Optional: JSON map of headers for RSS feeds ──────────────────────────
SOCIAL_RSS_HEADERS={"creator_feed":{"Authorization":"Bearer replace-me"}}

# Optional — Long-form clipper (Agent 6): a Vimeo personal access token
VIMEO_ACCESS_TOKEN=

# Google / YouTube Data API v3 (OAuth2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth2callback
GOOGLE_REFRESH_TOKEN=

# Server
PORT=8080
DASHBOARD_PASSWORD=change-me

# Pipeline
PIPELINE_CRON=0 3 * * *
VIDEOS_PER_RUN=6
AUTOPILOT=true